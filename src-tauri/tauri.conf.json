{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "El Compa Claudio",
  "version": "0.1.0",
  "identifier": "com.compaclaudio.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "El Compa Claudio",
        "width": 320,
        "height": 380,
        "minWidth": 240,
        "minHeight": 280,
        "x": 120,
        "y": 120,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": true,
        "skipTaskbar": true,
        "shadow": false,
        "hiddenTitle": true,
        "titleBarStyle": "Transparent",
        "visibleOnAllWorkspaces": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
